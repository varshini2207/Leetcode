class Solution {
    public int minPartitions(String n) {
       
        char maxDigit = '0'; 
        

       
        for (int i=0;i<=n.length()-1;i++) {
         
            if (n.charAt(i) > maxDigit) {
                maxDigit = n.charAt(i); 
            }
        }

       
        return maxDigit - '0'; 
    }
}
